pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Unit Test') {
            steps {
                dir('Chapter08/sample1') {
                    sh 'bash gradlew test'
                }
            }
        }
        stage('Code Coverage') {
            when {
                branch 'master'
            }
            steps {
                dir('Chapter08/sample1') {
                    sh 'bash gradlew jacocoTestReport'
                    sh 'bash gradlew jacocoTestCoverageVerification'
                }
            }
        }
    }
    post {
        always {
            dir('Chapter08/sample1') {
                sh 'bash gradlew jacocoTestReport || true'
            }
        }
        success {
            echo 'tests pass!'
        }
        failure {
            echo 'tests fail!'
        }
    }
}