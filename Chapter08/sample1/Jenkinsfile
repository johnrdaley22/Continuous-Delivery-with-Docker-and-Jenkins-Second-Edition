// Exercise 5 pipeline
pipeline {
    agent {
        label 'docker-agent'
    }
    triggers {
        pollSCM('* * * * *')
    }
    stages {
        stage('Compile') {
            steps {
                dir('Chapter08/sample1') {
                    sh 'bash gradlew compileJava'
                }
            }
        }
        stage('Unit test') {
            steps {
                dir('Chapter08/sample1') {
                    sh 'bash gradlew test'
                }
            }
        }
        stage('Code coverage') {
            when {
                changeset '**/*.java'
            }
            steps {
                dir('Chapter08/sample1') {
                    sh 'bash gradlew jacocoTestReport'
                    sh 'bash gradlew jacocoTestCoverageVerification'
                }
            }
        }
        stage('Checkstyle') {
            when {
                changeset '**/*.java'
            }
            steps {
                dir('Chapter08/sample1') {
                    sh 'bash gradlew checkstyleTest'
                }
            }
            post {
                always {
                    publishHTML(target: [
                        reportName: 'jacoco checkstyle',
                        reportDir: 'Chapter08/sample1/build/reports/checkstyle',
                        reportFiles: 'test.html',
                        alwaysLinkToLastBuild: true,
                        keepAll: true
                    ])
                }
            }
        }
    }
    post {
        success {
            echo 'pipeline ran perfectly'
        }
        failure {
            echo 'pipeline failure'
        }
    }
}